generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model HiringManager {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  phone      String?
  subject    String      @default("Coding")
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  candidates Candidate[]
}

model Candidate {
  id              String          @id @default(uuid())
  firstName       String
  lastName        String
  email           String          @unique
  phone           String          @unique
  position        String
  experience      Int
  expectedSalary  Float?
  currentLocation String?
  cvDriveLink     String?
  motivation      String?
  cvText          String?
  status          String          @default("APPLIED")
  rejectionReason String?
  layer1Score     Float?
  aiMotivationScore Float?
  aiCvScore       Float?
  applicationScore Float?
  finalScore      Float?
  hiringManagerId String?
  hiringManager   HiringManager?  @relation(fields: [hiringManagerId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assessments     Assessment[]
}

model Assessment {
  id          String   @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  token       String   @unique @default(uuid())
  status      String   @default("PENDING")
  mcqScore    Float?
  audioScore  Float?
  finalScore  Float?
  expiresAt   DateTime
  startedAt   DateTime?
  completedAt DateTime?
  topic       String?
  mcqQuestions Json?
  antiCheat   Json?
  reminderCount   Int       @default(0)
  lastReminderAt  DateTime?
  introAudioDriveLink String?
  audioDriveLink String?
  aiSpeechRawScores Json?
  aiSpeechTranscript String?
  audioPrompts  Json?
  audioResponses Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Question {
  id            String   @id @default(uuid())
  subject       String   @default("coding")
  category      String
  questionText  String
  options       Json
  correctAnswer String
  difficulty    String   @default("MEDIUM")
  createdAt     DateTime @default(now())
}

model AudioQuestion {
  id            String   @id @default(uuid())
  subject       String   @default("coding")
  questionText  String
  createdAt     DateTime @default(now())
}
