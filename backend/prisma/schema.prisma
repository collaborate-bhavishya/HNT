generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model HiringManager {
  id         String      @id @default(uuid())
  name       String
  email      String      @unique
  password   String
  phone      String?
  isActive            Boolean     @default(true)
  isAutoAssignEnabled Boolean     @default(false)
  lastAssignedAt      DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  subject             String      @default("Coding")
  candidates  Candidate[]
}

model QualityTeam {
  id                  String      @id @default(uuid())
  name                String
  email               String      @unique
  pin                 String      // 4-digit PIN (encrypted)
  subject             String      @default("Coding")
  isActive            Boolean     @default(true)
  isAutoAssignEnabled Boolean     @default(false)
  lastAssignedAt      DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  candidates          Candidate[]
}

model Candidate {
  id                String         @id @default(uuid())
  firstName         String
  lastName          String
  email             String         @unique
  phone             String         @unique
  position          String
  experience        Int
  expectedSalary    Float?
  currentLocation   String?
  cvDriveLink       String?
  status            String         @default("APPLIED")
  rejectionReason   String?
  layer1Score       Float?
  finalScore        Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  aiCvScore         Float?
  aiMotivationScore Float?
  applicationScore  Float?
  motivation        String?
  cvText            String?
  hiringManagerId   String?
  pin               String?
  assessments       Assessment[]
  hiringManager     HiringManager? @relation(fields: [hiringManagerId], references: [id])
  
  // Quality Review Fields
  qualityReviewLink   String?
  qualityReviewScore  Json?    // Rubrics: { subjectKnowledge: 1-10, engagement: 1-10, energy: 1-10, communication: 1-10 }
  qualityReviewResult String?  // SELECTED_FOR_TRAINING | REJECTED
  qualityTeamId       String?
  qualityTeam         QualityTeam? @relation(fields: [qualityTeamId], references: [id])
}

model Assessment {
  id                  String    @id @default(uuid())
  candidateId         String
  token               String    @unique @default(uuid())
  status              String    @default("PENDING")
  mcqScore            Float?
  finalScore          Float?
  expiresAt           DateTime
  startedAt           DateTime?
  completedAt         DateTime?
  antiCheat           Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  aiSpeechRawScores   Json?
  aiSpeechTranscript  String?
  audioDriveLink      String?
  audioScore          Float?
  mcqQuestions        Json?
  topic               String?
  introAudioDriveLink String?
  lastReminderAt      DateTime?
  reminderCount       Int       @default(0)
  audioPrompts        Json?
  audioResponses      Json?
  candidate           Candidate @relation(fields: [candidateId], references: [id])
}

model Question {
  id            String   @id @default(uuid())
  category      String
  questionText  String
  options       Json
  correctAnswer String
  difficulty    String   @default("MEDIUM")
  createdAt     DateTime @default(now())
  subject       String   @default("coding")
}

model AudioQuestion {
  id           String   @id @default(uuid())
  subject      String   @default("coding")
  questionText String
  createdAt    DateTime @default(now())
}

model SubjectDashboardConfig {
  id                String   @id @default(uuid())
  subject           String   @unique
  mockInterviewLink String?
  trainingNodes     Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
